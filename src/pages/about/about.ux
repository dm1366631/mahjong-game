  color: #ffd54a;
  margin-bottom: 4px;
}

.version {
  font-size: 13px;
  color: #8aa0c4;
  margin-bottom: 16px;
}

.info-section {
  width: 100%;
  flex-direction: row;
  justify-content: space-between;
  padding: 8px 12px;
  background-color: #1a2b4a;
  border-radius: 6px;
  margin-bottom: 6px;
}

.info-title {
  font-size: 13px;
  color: #8aa0c4;
}

.info-text {
  font-size: 13px;
  color: #cfe0ff;
}

.version-box {
  width: 100%;
  flex-direction: column;
  padding: 10px;
  background-color: #132440;
  border-radius: 6px;
  margin-top: 12px;
  align-items: center;
}

.version-label {
  font-size: 12px;
  color: #8aa0c4;
  margin-bottom: 6px;
}

.version-input {
  width: 90px;
  height: 32px;
  font-size: 13px;
  color: #cfe0ff;
  text-align: center;
  background-color: #1a2b4a;
  border: 1px solid #3a5580;
  border-radius: 4px;
}

.unlock-hint {
  font-size: 11px;
  color: #7fcf9a;
  margin-top: 8px;
}

.unlock-success {
  font-size: 13px;
  color: #7fcf9a;
  margin-top: 8px;
  font-weight: bold;
}

.footer {
  padding: 8px 12px;
  border-top: 1px solid #2a4060;
  align-items: center;
}

.btn {
  height: 36px;
  border-radius: 6px;
  font-size: 15px;
  border: none;
}

.back-btn {
  width: 120px;
  color: #cfe0ff;
  background-color: transparent;
  border: 1px solid #3a5580;
}
</style>
