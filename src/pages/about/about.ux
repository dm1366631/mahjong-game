<template>
  <div class="page">
    <text class="title">关于</text>

    <div class="content">
      <text class="app-name">杭州麻将</text>
      <text class="version">版本 {{version}}</text>
      
      <div class="info-section">
        <text class="info-title">开发者</text>
        <text class="info-text">openblack</text>
      </div>
      
      <div class="info-section">
        <text class="info-title">规则</text>
        <text class="info-text">杭州麻将（白板财神）</text>
      </div>
      
      <div class="info-section">
        <text class="info-title">适配设备</text>
        <text class="info-text">小米手环10 NFC</text>
      </div>
      
      <div class="version-box" onclick="onVersionClick">
        <text class="version-label">版本号</text>
        <input class="version-input" type="text" value="{{version}}" disabled="true" />
      </div>
      
      <text class="unlock-hint" show="{{clickCount > 0 && clickCount < unlockCount}}">
        再点击{{unlockCount - clickCount}}次解锁隐藏选项
      </text>
      
      <text class="unlock-success" show="{{placeholderUnlocked}}">
        ✓ 已解锁占位图样式
      </text>
    </div>

    <div class="footer">
      <input class="btn back-btn" type="button" value="返回" onclick="goBack" />
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import storage from "@system.storage"

export default {
  private: {
    version: '1.0.0',
    clickCount: 0,
    unlockCount: 7,
    placeholderUnlocked: false
  },
  
  onInit() {
    storage.get({
      key: 'placeholderUnlocked',
      success: (data) => {
        this.placeholderUnlocked = (data === 'true')
      },
      fail: () => {}
    })
  },
  
  onVersionClick() {
    if (this.placeholderUnlocked) return
    
    this.clickCount++
    
    if (this.clickCount >= this.unlockCount) {
      this.placeholderUnlocked = true
      storage.set({
        key: 'placeholderUnlocked',
        value: 'true',
        success: () => {},
        fail: () => {}
      })
      this.clickCount = 0
    }
  },
  
  goBack() {
    router.back()
  }
}
</script>

